#include <iostream>
using namespace std;

int main()
{
    int n;
    cin >> n;

    int arr[n];
    for (int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    int i = 0;
    int j = n - 1;

    while (i < j)
    {
        int temp = arr[i];
        arr[i] = arr[j];
        arr[j] = temp;
        i++;
        j--;
    }

    for (int k = 0; k < n; k++)
    {
        cout << arr[k] << " ";
    }
}

//To reverse the array without using extra space, I used a two-pointer approach.
I initialized one pointer at the beginning of the array (i = 0) and another at the end (j = n - 1).
Then, I swapped the elements at these two positions and moved the pointers towards each other — incrementing i and decrementing j.
I repeated this process until both pointers met or crossed.
This way, the array gets reversed in-place without using any additional memory
