 #include <bits/stdc++.h>
using namespace std;

int main() {

    int n;
    cin >> n;

    int arr[n];

    for(int i = 0; i < n - 1; i++) {
        cin >> arr[i];
    }

    int arraySum = 0;

    for(int i = 0; i < n - 1; i++) {
        arraySum += arr[i];
    }

    int totalSum = n * (n + 1) / 2;

    int missing = totalSum - arraySum;

    cout << missing;

    return 0;
}
